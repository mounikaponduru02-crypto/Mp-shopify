{%- comment -%}
  Collection filters. Uses the global `collection` object.
  Renders price_range filters as min/max number inputs and list filters as
  checkboxes with counts, plus a reset link. Configure filters in the
  Shopify Search & Discovery app.
{%- endcomment -%}
<form class="form-filter" x-ref="filterForm">
  {%- for filter in collection.filters -%}
    <div class="filter-group">
      <label class="filter-group__title">{{ filter.label }}</label>

      {%- case filter.type -%}
        {%- when 'price_range' -%}
          <div class="filter-price-container flex justify-between align-center gap-10">
            <div class="filter-input w-100">
              <label class="filter-input__label" for="{{ filter.label }}-min">From</label>
              <input
                class="filter-input__field"
                type="number"
                @keydown.debounce.500ms="filterCollection()"
                name="{{ filter.min_value.param_name }}"
                id="{{ filter.label }}-min"
                placeholder="0"
                {% if filter.min_value.value %}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                min="0"
                max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
              >
            </div>
            <div class="filter-input w-100">
              <label class="filter-input__label" for="{{ filter.label }}-max">To</label>
              <input
                class="filter-input__field"
                type="number"
                @keydown.debounce.500ms="filterCollection()"
                name="{{ filter.max_value.param_name }}"
                id="{{ filter.label }}-max"
                placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                {% if filter.max_value.value %}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                min="0"
                max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
              >
            </div>
          </div>

        {%- when 'list' -%}
          <ul class="filter-list list-style-none">
            {%- for value in filter.values -%}
              <li class="filter-list__item">
                <label class="filter-list__label" for="{{ filter.param_name }}-{{ forloop.index }}">
                  <input
                    type="checkbox"
                    @change="filterCollection()"
                    name="{{ value.param_name }}"
                    id="{{ filter.param_name }}-{{ forloop.index }}"
                    value="{{ value.value }}"
                    {% if value.active %}checked{% endif %}
                    {% if value.count == 0 and value.active == false %}disabled{% endif %}
                  >
                  <span class="filter-list__name">{{ value.label }}</span>
                  <span class="filter-list__count">({{ value.count }})</span>
                </label>
              </li>
            {%- endfor -%}
          </ul>
      {%- endcase -%}
    </div>
  {%- else -%}
    <p class="filter-empty">No filters available. Configure filters in Search &amp; Discovery.</p>
  {%- endfor -%}

</form>
