{% style %}
  #product_container {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #product_container .grid-2 {
    grid-template-columns: 420px minmax(0, 560px);
    justify-content: center;
    align-items: start;
  }

  @media (max-width: 900px) {
    #product_container .grid-2 {
      grid-template-columns: 1fr;
    }
  }

  .product-media {
    border-radius: 30px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  }
  .my-swiper .swiper-slide img {
    width: 100%;
    height: auto;
    display: block;
  }
  span.swiper-pagination-bullet {
    width: 20px;
    height: 20px;
    background: var(--primary-color);
  }
  span.swiper-pagination-bullet-active {
    background: var(--secondary-color);
  }

  /* Product information */
  .product-vendor {
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 13px;
    font-weight: 600;
    color: #6b7280;
    margin-bottom: 6px;
  }
  .product-sku {
    font-size: 13px;
    color: #6b7280;
    margin-bottom: 12px;
  }
  .product-price {
    font-size: 26px;
    font-weight: 700;
    color: #121212;
    margin-bottom: 18px;
  }
  .product-price__was {
    color: #9ca3af;
    font-weight: 500;
    font-size: 18px;
  }
  .product-description {
    color: #3a3a44;
    line-height: 1.7;
    margin-bottom: 20px;
  }

  /* Quantity field */
  .quantity-field-container {
    margin: 20px 0;
  }
  .quantity-field-container label {
    display: flex;
    font-size: 20px;
    font-weight: bold;
    margin-bottom: 10px;
  }
  .quantity-field {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    max-width: 180px;
    border: 1px solid var(--secondary-color);
    border-radius: 50px;
    padding: 8px 14px;
  }
  .qty-button {
    width: 40px;
    height: 40px;
    background: var(--secondary-color);
    border: none;
    border-radius: 50%;
    cursor: pointer;
  }
  .quantity-field input {
    width: 50px;
    height: 40px;
    text-align: center;
    font-size: 20px;
    border: none;
    background: transparent;
  }
  .quantity-field input:focus {
    outline: none;
  }

  /* Variant selector */
  .variant-dropdown {
    margin: 20px 0;
  }
  .variant-dropdown h2 {
    margin-bottom: 10px;
  }
  .variant-option {
    display: flex;
    width: 100%;
    padding: 20px 10px;
    font-size: 20px;
  }

  /* Variant swatches */
  .variant-swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 4px;
  }
  .product-swatches {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }
  .swatch {
    cursor: pointer;
    transition: box-shadow 0.2s ease, border-color 0.2s ease, color 0.2s ease, transform 0.1s ease;
    user-select: none;
  }
  .swatch:active { transform: scale(0.94); }

  /* Color swatches */
  .swatch--color {
    display: inline-block;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--swatch-color, #cccccc);
    box-shadow: 0 0 0 1px #d1d5db;
  }
  .swatch--color:hover {
    box-shadow: 0 0 0 2px var(--secondary-color);
  }
  .product-swatches:checked + .swatch--color {
    box-shadow: 0 0 0 3px #ffffff, 0 0 0 5px var(--secondary-color);
  }

  /* Text swatches (size, etc.) */
  .swatch--text {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #ffffff;
    border: 1px solid #d1d5db;
    font-size: 15px;
    font-weight: 500;
    color: #121212;
  }
  .swatch--text:hover { border-color: var(--secondary-color); }
  .product-swatches:checked + .swatch--text {
    border: 2px solid var(--secondary-color);
    color: var(--secondary-color);
  }
  .product-swatches:focus-visible + .swatch {
    outline: 2px solid var(--secondary-color);
    outline-offset: 2px;
  }

  /* Image swatches */
  .swatch--image {
    display: inline-block;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    overflow: hidden;
    box-shadow: 0 0 0 1px #d1d5db;
  }
  .swatch--image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .swatch--image:hover {
    box-shadow: 0 0 0 2px var(--secondary-color);
  }
  .product-swatches:checked + .swatch--image {
    box-shadow: 0 0 0 3px #ffffff, 0 0 0 5px var(--secondary-color);
  }

  /* Full product description (below the product info) */
  .product-full-description {
    margin: 40px 0;
    line-height: 1.7;
    color: #3a3a44;
  }
  .product-full-description img {
    width: 100%;
    height: auto;
    border-radius: 12px;
    margin: 16px 0;
  }
  .product-full-description > *:last-child {
    margin-bottom: 0;
  }

  /* Mobile */
  @media (max-width: 767px) {
    .page-header .title-container {
      height: 90px;
    }
    .page-header .title-container h1 {
      font-size: 30px;
    }
    #product_container {
      padding-top: 24px;
      padding-bottom: 24px;
    }
  }
{% endstyle %}

<script>
  window.product = {{ product | json }};
</script>

<div class="page-header">
  <div class="max-width mx-auto px-10">
    <div class="title-container py-20">
      <h1>{{ product.title }}</h1>
    </div>
  </div>
</div>

<div class="max-width mx-auto px-10" id="product_container">
  <div class="grid grid-2 gap-40">
    <div class="product-media overflow-hidden">
      <div class="swiper my-swiper">
        <div class="swiper-wrapper">
          {%- assign index = 0 -%}
          {%- for item in product.images -%}
            <div class="swiper-slide" id="{{ item.id }}" data-index="{{ index }}">
              {%- assign index = index | plus: 1 -%}
              <img
                src="{{ item | image_url: width: 1000 }}"
                srcset="
                  {{ item | image_url: width: 400 }} 400w,
                  {{ item | image_url: width: 600 }} 600w,
                  {{ item | image_url: width: 800 }} 800w,
                  {{ item | image_url: width: 1000 }} 1000w,
                  {{ item | image_url: width: 1200 }} 1200w
                "
                sizes="(max-width: 749px) 100vw, 45vw"
                alt="{{ product.title | escape }}"
                width="{{ item.width }}"
                height="{{ item.height }}"
                loading="lazy"
              >
            </div>
          {%- endfor -%}
        </div>
        <div class="swiper-pagination"></div>
      </div>
    </div>

    <div class="product-information" data-section="{{ section.id }}" data-url="{{ product.url }}">
      {%- assign selected_variation = product.selected_or_first_available_variant -%}
      {%- assign form_id = 'product-form-' | append: section.id -%}

      {%- form 'product', product, id: form_id, novalidate: 'novalidate' -%}
        <input type="hidden" name="id" id="variation_id" value="{{ selected_variation.id }}">

        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'vendor' -%}
              <p class="product-vendor" {{ block.shopify_attributes }}>{{ product.vendor }}</p>

            {%- when 'sku' -%}
              {%- if selected_variation.sku != blank -%}
                <p class="product-sku" {{ block.shopify_attributes }}>{{ selected_variation.sku }}</p>
              {%- endif -%}

            {%- when 'price' -%}
              <div id="price-{{ section.id }}" class="flex gap-10 align-center product-price" {{ block.shopify_attributes }}>
                {%- if selected_variation.compare_at_price > selected_variation.price -%}
                  <span class="product-price__current">{{ selected_variation.price | money }}</span>
                  <s class="product-price__was">{{ selected_variation.compare_at_price | money }}</s>
                {%- else -%}
                  <span class="product-price__current">{{ selected_variation.price | money }}</span>
                {%- endif -%}
              </div>

            {%- when 'variant_selector' -%}
              {%- unless product.has_only_default_variant -%}
                <div {{ block.shopify_attributes }}>
                  {%- for product_option in product.options_with_values -%}
                    {%- assign option_index = forloop.index -%}
                    {%- if section.settings.product_variance == 'swatches' -%}
                      {%- assign opt_name = product_option.name | downcase -%}
                      {%- assign is_color = false -%}
                      {%- if opt_name contains 'color' or opt_name contains 'colour' -%}
                        {%- assign is_color = true -%}
                      {%- endif -%}
                      <div class="variant-dropdown">
                        <h2>{{ product_option.name }}</h2>
                        <div class="variant-swatches">
                          {%- for value in product_option.values -%}
                            {%- assign swatch_id = 'swatch-' | append: section.id | append: '-' | append: option_index | append: '-' | append: forloop.index -%}
                            <input
                              type="radio"
                              class="product-swatches"
                              id="{{ swatch_id }}"
                              name="options[{{ product_option.name }}]"
                              value="{{ value }}"
                              data-index="option{{ option_index }}"
                              {% if product_option.selected_value == value %}checked{% endif %}
                            >
                            {%- if value.swatch.image -%}
                              <label class="swatch swatch--image" for="{{ swatch_id }}" title="{{ value | escape }}">
                                <img src="{{ value.swatch.image | image_url: width: 100 }}" alt="{{ value | escape }}" width="46" height="46" loading="lazy">
                                <span class="visually-hidden">{{ value }}</span>
                              </label>
                            {%- elsif value.swatch.color -%}
                              <label class="swatch swatch--color" for="{{ swatch_id }}" style="--swatch-color: {{ value.swatch.color }};" title="{{ value | escape }}">
                                <span class="visually-hidden">{{ value }}</span>
                              </label>
                            {%- elsif is_color -%}
                              <label class="swatch swatch--color" for="{{ swatch_id }}" style="--swatch-color: {{ value | downcase | strip | replace: ' ', '' }};" title="{{ value | escape }}">
                                <span class="visually-hidden">{{ value }}</span>
                              </label>
                            {%- else -%}
                              <label class="swatch swatch--text" for="{{ swatch_id }}">{{ value }}</label>
                            {%- endif -%}
                          {%- endfor -%}
                        </div>
                      </div>
                    {%- else -%}
                      <div class="variant-dropdown">
                        <h2>{{ product_option.name }}</h2>
                        <select class="variant-option" name="options[{{ product_option.name }}]" data-index="option{{ option_index }}">
                          {%- for value in product_option.values -%}
                            <option value="{{ value }}" {% if product_option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                          {%- endfor -%}
                        </select>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endunless -%}

            {%- when 'quantity' -%}
              <div class="quantity-field-container" {{ block.shopify_attributes }}>
                <label for="quantity">Quantity</label>
                <div
                  class="quantity-field"
                  x-data="{ count: 1, increment() { this.count++ }, decrement() { if (this.count > 1) { this.count-- } } }"
                >
                  <button type="button" class="qty-button flex align-center justify-center" @click="decrement">
                    {% render 'icon-minus' %}
                  </button>
                  <input type="text" id="quantity" name="quantity" value="1" readonly x-model="count">
                  <button type="button" class="qty-button flex align-center justify-center" @click="increment">
                    {% render 'icon-plus' %}
                  </button>
                </div>
              </div>

            {%- when 'description' -%}
              {%- if product.metafields.custom.short_description != blank -%}
                <div class="product-description" {{ block.shopify_attributes }}>{{ product.metafields.custom.short_description.value | newline_to_br }}</div>
              {%- else -%}
                {%- assign first_para = product.description | split: '</p>' | first -%}
                <div class="product-description" {{ block.shopify_attributes }}>{{ first_para | strip_html }}</div>
              {%- endif -%}

            {%- when 'buttons' -%}
              <div {{ block.shopify_attributes }}>
                <button
                  type="button"
                  id="add-to-cart"
                  class="btn btn--primary my-10"
                  {% if selected_variation.available == false %}disabled{% endif %}
                >
                  {%- if selected_variation.available == false -%}
                    Sold out
                  {%- else -%}
                    Add to cart
                  {%- endif -%}
                </button>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      {%- endform -%}
    </div>
  </div>
</div>

{%- if product.description != blank -%}
  <div class="max-width mx-auto px-10">
    <div class="product-full-description rte">
      {{ product.description }}
    </div>
  </div>
{%- endif -%}

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var productSwiper = new Swiper('.my-swiper', {
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      },
    });

    function goToSlide(index) {
      productSwiper.slideTo(index);
    }

    var addToCartBtn = document.getElementById('add-to-cart');
    var loader = document.getElementById('loader');

    // Re-fetch the header section and swap the mini-cart contents + count.
    function refreshMiniCart() {
      return fetch(window.location.pathname + '?section_id=header')
        .then(function (r) { return r.text(); })
        .then(function (html) {
          var doc = new DOMParser().parseFromString(html, 'text/html');
          var newContent = doc.querySelector('[data-cart-drawer-content]');
          var content = document.querySelector('[data-cart-drawer-content]');
          if (newContent && content) content.innerHTML = newContent.innerHTML;

          var newCount = doc.querySelector('[data-cart-count]');
          var count = newCount ? newCount.textContent.trim() : '0';
          document.querySelectorAll('[data-cart-count]').forEach(function (el) {
            el.textContent = count;
            el.classList.toggle('is-empty', count === '0');
          });
          var label = document.querySelector('[data-cart-count-label]');
          if (label) label.textContent = '(' + count + ')';
        });
    }

    if (addToCartBtn) {
      addToCartBtn.addEventListener('click', function () {
        loader.classList.remove('hidden');
        loader.classList.add('flex');

        var id = document.getElementById('variation_id').value;
        var qty = document.getElementById('quantity').value;

        var formData = {
          items: [{ id: id, quantity: qty }]
        };

        fetch(window.Shopify.routes.root + 'cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(formData)
        })
          .then(function (response) { return response.json(); })
          .then(function () { return refreshMiniCart(); })
          .then(function () {
            loader.classList.add('hidden');
            loader.classList.remove('flex');
            var cartOpen = document.querySelector('[data-cart-open]');
            if (cartOpen) cartOpen.click();
          })
          .catch(function (error) {
            loader.classList.add('hidden');
            loader.classList.remove('flex');
            console.error('Add to cart error:', error);
          });
      });
    }

    // ----- Variant selector -----
    // Dropdown selects
    function getOptions() {
      var variantArray = [];
      document.querySelectorAll('.variant-option').forEach(function (el) {
        variantArray.push({ value: el.value, index: el.getAttribute('data-index') });
      });
      return variantArray;
    }

    // Swatch radios (only the checked one per option group)
    function getOptionsSwatches() {
      var variantArray = [];
      document.querySelectorAll('.product-swatches:checked').forEach(function (el) {
        variantArray.push({ value: el.value, index: el.getAttribute('data-index') });
      });
      return variantArray;
    }

    function getCurrentVariant(selectedValues) {
      var currentVariant = null;
      var variants = window.product.variants;
      variants.forEach(function (variant) {
        var satisfied = true;
        selectedValues.forEach(function (option) {
          if (variant[option.index] != option.value) {
            satisfied = false;
          }
        });
        if (satisfied) {
          currentVariant = variant;
        }
      });
      return currentVariant;
    }

    function updateProductUrl(variant) {
      var newUrl =
        window.location.protocol + '//' +
        window.location.host +
        window.location.pathname +
        '?variant=' + variant.id;
      window.history.replaceState({ path: newUrl }, '', newUrl);
    }

    function updateVariationId(variant) {
      var idField = document.getElementById('variation_id');
      if (idField) idField.value = variant.id;
    }

    function updateButtonText(variant) {
      if (!addToCartBtn) return;
      if (variant.available == false) {
        addToCartBtn.innerHTML = 'Sold out';
        addToCartBtn.setAttribute('disabled', 'disabled');
      } else {
        addToCartBtn.innerHTML = 'Add to cart';
        addToCartBtn.removeAttribute('disabled');
      }
    }

    function updateSku(variant) {
      var skuEl = document.querySelector('.product-sku');
      if (skuEl && variant.sku) {
        skuEl.textContent = variant.sku;
      }
    }

    function updateSliderImage(variant) {
      if (!variant.featured_image) return;
      var slide = document.getElementById(variant.featured_image.id);
      if (!slide) return;
      var index = slide.getAttribute('data-index');
      goToSlide(parseInt(index, 10));
    }

    async function updatePrice(currentVariant, productUrl, sectionId) {
      if (!currentVariant || !productUrl || !sectionId) return;
      try {
        var url = productUrl + '?variant=' + currentVariant.id + '&section_id=' + sectionId;
        var response = await fetch(url);
        var data = await response.text();
        var parser = new DOMParser();
        var parsedHTML = parser.parseFromString(data, 'text/html');
        var newPrice = parsedHTML.getElementById('price-' + sectionId);
        var currentPrice = document.getElementById('price-' + sectionId);
        if (newPrice && currentPrice) {
          currentPrice.innerHTML = newPrice.innerHTML;
        }
      } catch (error) {
        console.error('Update price error:', error);
      }
    }

    var productInfo = document.querySelector('.product-information');
    var sectionId = productInfo ? productInfo.getAttribute('data-section') : null;
    var productUrl = productInfo ? productInfo.getAttribute('data-url') : null;

    // Run all variant-dependent UI updates for the matched variant.
    function applyVariant(currentVariant) {
      if (!currentVariant) return;
      updateProductUrl(currentVariant);
      updateVariationId(currentVariant);
      updateButtonText(currentVariant);
      updateSliderImage(currentVariant);
      updatePrice(currentVariant, productUrl, sectionId);
      // updateSku(currentVariant); // enable when variants have per-variant SKUs
    }

    // Dropdown selectors
    document.querySelectorAll('.variant-option').forEach(function (selectedElement) {
      selectedElement.addEventListener('change', function () {
        applyVariant(getCurrentVariant(getOptions()));
      });
    });

    // Swatch selectors
    document.querySelectorAll('.product-swatches').forEach(function (selectedElement) {
      selectedElement.addEventListener('change', function () {
        applyVariant(getCurrentVariant(getOptionsSwatches()));
      });
    });
  });
</script>

{% schema %}
{
  "name": "Main product",
  "settings": [
    {
      "type": "select",
      "id": "product_variance",
      "label": "Choose product variants style",
      "default": "dropdown",
      "options": [
        { "value": "dropdown", "label": "Dropdown" },
        { "value": "swatches", "label": "Swatches" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 48
    }
  ],
  "blocks": [
    { "type": "vendor", "name": "Vendor", "limit": 1, "settings": [] },
    { "type": "sku", "name": "SKU", "limit": 1, "settings": [] },
    { "type": "price", "name": "Price", "limit": 1, "settings": [] },
    { "type": "quantity", "name": "Quantity", "settings": [] },
    { "type": "variant_selector", "name": "Variant selector", "settings": [] },
    { "type": "description", "name": "Description", "settings": [] },
    { "type": "buttons", "name": "Checkout buttons", "settings": [] }
  ]
}
{% endschema %}
